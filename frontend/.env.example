# Next.js BFF settings.
# These are server-side values and must not use NEXT_PUBLIC_*.
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=

# Auth.js settings.
AUTH_SECRET=
APP_USERNAME=admin
APP_PASSWORD_HASH=

# Optional local display override. Vercel normally provides this automatically.
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=
