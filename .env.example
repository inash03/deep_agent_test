# ---------------------------------------------------------------------------
# シークレットバックエンドの選択
# ---------------------------------------------------------------------------
# SECRET_BACKEND=env  (デフォルト) → このファイルの値を使う
# SECRET_BACKEND=gcp               → GCP Secret Manager から取得する
SECRET_BACKEND=env

# GCP Secret Manager を使う場合のみ必要
# GCP プロジェクト ID（GCP コンソールのプロジェクト選択欄で確認できる）
GCP_PROJECT_ID=

# ---------------------------------------------------------------------------
# シークレット（SECRET_BACKEND=env の場合はここに値を記入）
# SECRET_BACKEND=gcp の場合はこれらを GCP Secret Manager に登録する:
#   ANTHROPIC_API_KEY → シークレット名: anthropic-api-key
#   DATABASE_URL      → シークレット名: database-url
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# PostgreSQL 接続文字列
# Neon の場合: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# (Neon コンソール → プロジェクト → Connection Details → Connection string でコピーできる)
DATABASE_URL=

# ---------------------------------------------------------------------------
# フロントエンド設定（VM の .env のみ。Cloud Run バックエンドには不要）
# ---------------------------------------------------------------------------
# Cloud Run 移行後: VITE_API_URL は CI/CD が自動更新するため手動設定不要
# ローカル開発時: http://localhost:8000
VITE_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# CORS 設定（GitHub Actions の GCP_VM environment secret "CORS_ORIGINS" に登録）
# ---------------------------------------------------------------------------
# フロントエンドの URL（Cloud Run バックエンドが許可するオリジン）
# 例: http://35.208.xxx.xxx:5173
# VM IP が変わった場合は GitHub Secrets の CORS_ORIGINS も更新すること
CORS_ORIGINS=http://localhost:5173
