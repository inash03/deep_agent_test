# ---------------------------------------------------------------------------
# Backend runtime
# ---------------------------------------------------------------------------
SECRET_BACKEND=env
GCP_PROJECT_ID=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DATABASE_URL=

# FastAPI protects LLM/action endpoints with X-API-Key when this is set.
# In Cloud Run, register the same value in Secret Manager as "api-key".
API_KEY=

# Allow the Vercel production URL and any preview URL policy you choose.
# Local Next.js development usually runs on http://localhost:3000.
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Next.js / Vercel frontend
# ---------------------------------------------------------------------------
# Server-side BFF settings. These must not be exposed as NEXT_PUBLIC_*.
BACKEND_API_URL=http://localhost:8000
BACKEND_API_KEY=

# Auth.js
AUTH_SECRET=
APP_USERNAME=admin
APP_PASSWORD_HASH=

# Optional client-visible Vercel commit SHA for version display.
NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA=

# ---------------------------------------------------------------------------
# MCP calendar demo
# ---------------------------------------------------------------------------
MCP_EUR_COUNTRY=DE
MCP_CALENDAR_HTTP_TIMEOUT_SECONDS=5
MCP_CALENDAR_DISABLE=false
MCP_CALENDAR_DIRECT_FALLBACK=true

# ---------------------------------------------------------------------------
# MCP external-data server (Cloud Run Service B — SSE transport)
# ---------------------------------------------------------------------------
# URL of the external-data MCP server's SSE endpoint.
# Local development: run `python mcp_server/external_data_server.py` first.
MCP_EXTERNAL_DATA_URL=http://localhost:8080/sse

# Set to 1 to bypass the MCP server and call the ECB API directly.
# Useful for local development when Service B is not running.
MCP_EXTERNAL_DATA_DISABLE=1
